# OpenAI API key for AI-powered document extraction
# OPENAI_API_KEY=

# Database URL for PostgreSQL (leave unset for SQLite)
# DATABASE_URL=

# Encryption key for sensitive health data (32 bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Backup schedule (cron expression, default: daily at 2 AM)
# BACKUP_SCHEDULE=0 2 * * *

# Hostnames that should redirect to the apex domain's /portal route
# PORTAL_HOSTNAMES=portal.peak360.com.au

# Apex hostname for the portal redirect target (cross-domain)
# APEX_HOSTNAME=peak360.com.au

# Primary admin auto-seed credentials. If both are set and no admin user exists,
# the app creates one on first boot. Idempotent — safe to leave set permanently.
# PRIMARY_SEED_ADMIN_USERNAME=admin@peak360.com.au
# PRIMARY_SEED_ADMIN_PASSWORD=

# LANDING_PASSWORD: hardcoded in src/app/api/landing-gate/route.ts (currently 'peakage').
# No env var needed.

# HMAC secret for signing the landing_gate cookie. Required in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset in development, the gate fails open (allows access). In production,
# if unset, all non-exempt paths redirect to /gate so the misconfiguration is visible.
# LANDING_GATE_SECRET=

# SMTP2Go API key for transactional + contact-form emails (HTTP API).
# If unset, emails are logged to the console instead of sent.
# SMTP2GO_API_KEY=
# From-address for outgoing email (defaults to noreply@peak360.com.au).
# EMAIL_FROM=

# Cloudflare Turnstile (landing contact form anti-bot).
# Client site key — exposed to the browser. If unset, the form falls back to
# Cloudflare's "always passes" TEST key so the widget renders in dev. Set a real
# key in production.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server secret key. When set, /api/contact verifies the Turnstile token and
# rejects failures. When unset, captcha verification is skipped (honeypot only).
# Both keys must be the matching pair from the same Turnstile widget.
# TURNSTILE_SECRET_KEY=
