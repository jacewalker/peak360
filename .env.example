# OpenAI API key for AI-powered document extraction
# OPENAI_API_KEY=

# Database URL for PostgreSQL (leave unset for SQLite)
# DATABASE_URL=

# Encryption key for sensitive health data (32 bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Backup schedule (cron expression, default: daily at 2 AM)
# BACKUP_SCHEDULE=0 2 * * *
